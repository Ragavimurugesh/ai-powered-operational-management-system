    "import os\n",
    "if os.path.exists(\"opsmind.db\"):\n",
    "    os.remove(\"opsmind.db\")\n",
    "    print(\"Database deleted ✅\")\n",
    "else:\n",
    "    print(\"Database not found\")\n",
    "\n",
    "from database import Base, engine\n",
    "Base.metadata.create_all(bind=engine)\n",
    "print(\"New database created ✅\")\n",
    "\n",
    "exit()\n"
   ]
